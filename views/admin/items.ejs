<!doctype html>
<html>
<head>
  <title>Manage Items — Countryside Paradise</title>
  <%- include("../includes/head") %>
</head>
<body>
  <%- include("../includes/header") %>

  <main style="padding:24px; max-width:800px; margin:0 auto;">
    <h2>Manage Add-On Items</h2>
    <p>Add or remove items customers can choose when booking.</p>

    <div class="card" style="margin:20px 0;">
      <form method="post" action="/admin/items/add" style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
        <div>
          <label for="name">Item Name</label><br>
          <input type="text" name="name" required placeholder="e.g. Extra chairs (per 10)">
        </div>
        <div>
          <label for="price_dollars">Price ($)</label><br>
          <input type="number" step="0.01" min="0" name="price_dollars" required>
        </div>
        <div style="align-self:flex-end;">
          <button type="submit">Add Item</button>
        </div>
      </form>
    </div>

    <h3>Current Items</h3>
    <table>
      <tr><th>ID</th><th>Name</th><th>Price</th><th>Actions</th></tr>
      <% items.forEach(function(i){ %>
        <tr>
          <td><%= i.id %></td>
          <td><%= i.name %></td>
          <td>$<%= (i.price_cents/100).toFixed(2) %></td>
          <td>
            <form method="post" action="/admin/items/delete" style="display:inline;">
              <input type="hidden" name="id" value="<%= i.id %>">
              <button type="submit" onclick="return confirm('Delete this item?')">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </table>
  </main>

  <%- include("../includes/footer") %>
</body>
</html>
