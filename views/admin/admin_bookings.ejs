<!doctype html>
<html>
<head>
  <title>Admin • Bookings</title>
  <%- include("../includes/head") %>
</head>
<body>
<header><%- include("../includes/header") %></header>
<main>
  <h1>Bookings</h1>
  <table class="table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Customer</th>
        <th>Contact</th>
        <th>Total</th>
        <th>Paid</th>
        <th>Remaining</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% bookings.forEach(b => { %>
        <tr>
          <td><%= b.date %></td>
          <td><%= b.customer_name || '-' %></td>
          <td>
            <div><%= b.customer_email || '-' %></div>
            <div><%= b.customer_phone || '-' %></div>
          </td>
          <td>$<%= (b.total_cents/100).toFixed(2) %></td>
          <td>$<%= (b.amount_paid_cents/100).toFixed(2) %></td>
          <td>$<%= (b.remaining_cents/100).toFixed(2) %></td>
          <td>
            <% if (b.remaining_cents > 0) { %>
              <form action="/admin/bookings/<%= b.id %>/send-reminder" method="POST" style="display:inline-block;">
                <button>Send Reminder</button>
              </form>
              <form action="/admin/bookings/<%= b.id %>/manual-payment" method="POST" style="display:inline-block;margin-left:6px;">
                <input type="number" step="0.01" name="amount_dollars" placeholder="Amt $" required>
                <button>Add Manual</button>
              </form>
            <% } else { %>
              <em>Paid in full</em>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</main>
<%- include("../includes/footer") %>
</body>
</html>
