<!doctype html>
<html>
<head>
  <title>Venue — Countryside Paradise</title>
  <%- include("includes/head") %>
</head>
<body>
  <header><%- include("includes/header") %></header>

  <main>
    <section style="padding: 48px 24px; text-align: center;">
      <div style="max-width: 900px; margin: 0 auto;">
        <img src="img/logo.jpeg" alt="Countryside Paradise logo" style="width: 128px; height: 128px; border-radius: 64px;">
        <h1 style="margin: 16px 0 8px;">Explore the Venue</h1>
        <p style="font-weight: 600; margin: 0 auto 16px; max-width: 760px;">
          Countryside Paradise offers flexible spaces that balance rustic charm with practical amenities.
          Plan an event that feels beautiful, comfortable, and easy to run from start to finish.
        </p>
        <a href="/book" class="card" style="padding:12px 16px; display:inline-block;">Book your date</a>
      </div>
    </section>

    <hr style="border:0; height:1px; background:#e6e6e6; margin: 0 24px;">

    <!-- BARN -->
    <section style="padding: 40px 24px;">
      <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1.1fr 1fr; gap: 24px; align-items: start;">
        <div>
          <h2 style="margin: 0 0 8px;">The Barn</h2>
          <p style="margin: 0 0 16px;">
            A spacious barn designed for comfort and convenience. Host ceremonies, receptions, or large gatherings with confidence
            while enjoying reliable amenities and flexible layout options.
          </p>
          <ul style="margin: 0 0 16px 18px; line-height: 1.6;">
            <li>Indoor heating, fans, and lighting for year round comfort</li>
            <li>Chairs and tables available with a variety of decorations</li>
            <li>Two bathrooms for guests, four sinks, and a spigot for filling buckets</li>
            <li>Audio system that connects to phones, laptops, or mixers by wire or by bluetooth</li>
            <li>Microphone included for announcements and toasts</li>
            <li>Shelves for serving food and staging items</li>
            <li>Large barn door that opens to the yard for an indoor to outdoor flow</li>
          </ul>
          <p style="margin: 0;">
            Arrange seating, food service, and sound the way your event needs. The barn can be the main venue or a central hub that opens into the outdoor spaces.
          </p>
        </div>
        <div style="display: grid; gap: 12px;">
          <img src="img/mic.webp" alt="Barn exterior or interior" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with a photo of the barn exterior or interior -->
          <img src="img/weddings.webp" alt="Barn details or decor" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with a close up of decor, shelves, or the barn door opening to the yard -->
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr style="border:0; height:1px; background:#e6e6e6; margin: 0 24px;">

    <!-- YARD -->
    <section style="padding: 40px 24px;">
      <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 24px; align-items: start;">
        <div style="display: grid; gap: 12px;">
          <img src="img/outdoors.jpg" alt="Yard overview" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with a wide shot of the open grassy yard -->
          <img src="img/yard.webp" alt="Stone pathways or covered area" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with stone pathways or the covered setup area -->
        </div>
        <div>
          <h2 style="margin: 0 0 8px;">The Yard</h2>
          <p style="margin: 0 0 16px;">
            A large open grassy area with stone pathways that is ideal for outdoor receptions and lively gatherings.
            Create a layout that fits a ceremony, a dinner, or a full evening of games and dancing.
          </p>
          <ul style="margin: 0 0 16px 18px; line-height: 1.6;">
            <li>Covered area for setting up food, drinks, or dessert stations</li>
            <li>Open space for arranging tables and chairs</li>
            <li>Perfect for sports, lawn games, and outdoor dancing</li>
            <li>Flexibility to stage the yard as a standalone setting or an extension of the barn</li>
          </ul>
          <p style="margin: 0;">
            Guide guests along the stone pathways and enjoy a layout that can shift from a ceremony to a reception without moving the party far from the action.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr style="border:0; height:1px; background:#e6e6e6; margin: 0 24px;">

    <!-- DINER -->
    <section style="padding: 40px 24px;">
      <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1.1fr 1fr; gap: 24px; align-items: start;">
        <div>
          <h2 style="margin: 0 0 8px;">The Diner</h2>
          <p style="margin: 0 0 16px;">
            A comfortable diner style space that supports food service and guest seating. It is practical for prep, plating, and casual meals.
          </p>
          <ul style="margin: 0 0 16px 18px; line-height: 1.6;">
            <li>Tables and seating for groups</li>
            <li>Cookware and utensils available for use</li>
            <li>Stove, microwave, and fridge for preparation and storage</li>
            <li>A good home base for catering teams and family helpers</li>
          </ul>
          <p style="margin: 0;">
            Use the diner for brunch, buffet prep, dessert tables, or a quiet spot for vendors to stage and coordinate.
          </p>
        </div>
        <div style="display: grid; gap: 12px;">
          <img src="img/diner0.webp" alt="Diner seating" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with a photo of tables and seating in the diner -->
          <img src="img/diner1.webp" alt="Diner kitchen appliances" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with a photo of the stove, microwave, fridge, or cookware -->
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr style="border:0; height:1px; background:#e6e6e6; margin: 0 24px;">

    <!-- POOL -->
    <section style="padding: 40px 24px;">
      <div style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.1fr; gap: 24px; align-items: start;">
        <div style="display: grid; gap: 12px;">
          <img src="img/pool0.webp" alt="Pool overview" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with a wide shot of the pool -->
          <img src="img/pool1.webp" alt="Shuffleboard and seating" style="width: 100%; height: auto; border-radius: 12px;">
          <!-- Fill src with the shuffleboard area and nearby tables and chairs -->
        </div>
        <div>
          <h2 style="margin: 0 0 8px;">The Pool</h2>
          <p style="margin: 0 0 16px;">
            A large pool area that works well for daytime events and evening gatherings. Guests can relax by the water while enjoying games and conversation.
          </p>
          <ul style="margin: 0 0 16px 18px; line-height: 1.6;">
            <li>Pool accessories that include noodles, floaters, and toys</li>
            <li>Shuffleboard area alongside the pool</li>
            <li>Tables and chairs for guests</li>
            <li>Pairs nicely with yard and barn activities for a full day experience</li>
          </ul>
          <p style="margin: 0;">
            Plan a casual afternoon by the water or add the pool as a relaxing transition between ceremony and reception.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <hr style="border:0; height:1px; background:#e6e6e6; margin: 0 24px;">

    <!-- Call to action -->
    <section style="padding: 40px 24px; text-align: center;">
      <div style="max-width: 900px; margin: 0 auto;">
        <h3 style="margin: 0 0 8px;">Ready to plan your event</h3>
        <p style="margin: 0 0 16px;">
          Choose the spaces that fit your vision. The barn, yard, diner, and pool can be used on their own or combined for a complete venue experience.
        </p>
        <a href="/book" class="card" style="padding:12px 16px; display:inline-block;">Book your date</a>
      </div>
    </section>
  </main>

  <%- include("includes/footer") %>
</body>
</html>
