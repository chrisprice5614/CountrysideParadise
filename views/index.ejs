<!doctype html>
<html>
<head>
  <title>Countryside Paradise</title>
  <%- include("includes/head") %>
</head>
<body>
  <header><%- include("includes/header") %></header>
  <main>
    <section style="background: url('img/chairs.jpg'); background-size: cover; padding: 48px 24px;">
      <div style="width: 100%;">
        <br>
        <div style="text-align: center;">
          <img src="img/logo.jpeg" alt="Countryside paradise logo" style="width: 128px; height: 128px; border-radius: 64px;">
        </div>

        <br>
        <h1 style="color: white; text-shadow: 2px 2px 6px rgba(0,0,0,0.6);">Elegant events in a rustic setting</h1>
        <p style="color: white; text-shadow: 2px 2px 8px rgba(0,0,0,0.6); font-weight: 600;">Our barn, big yard, and pool provide multiple beautiful spaces for weddings, birthdays, corporate events, and more.</p>
        <br>
        <div style="margin-top:18px;">
          <a href="/book" class="card" style="padding:12px; display:inline-block;">Book now</a>
        </div>
      </div>
    </section>

    <section style="padding: 24px 32px;">
      <div class="grid">
        <div class="card">
          <img src="/img/barn.jpg" alt="Image of the barn" style="width: 100%; height: auto; object-fit: cover; border-radius: 12px;">
          <h4>BARN</h4>
          <p>Rustic barn with timeless charm.</p>
        </div>
        <div class="card">
          <img src="/img/outdoors.jpg" alt="Image of the yard with people there." style="width: 100%; height: auto; object-fit: cover; border-radius: 12px;">
          <h4>YARD</h4>
          <p>Expansive yard for outdoor receptions and ceremonies.</p>
        </div>
        <div class="card">
          <img src="/img/pool.jpg" alt="Image of the pool" style="width: 100%; height: auto; object-fit: cover; border-radius: 12px;">
          <h4>POOL</h4>
          <p>Poolside area for daytime or evening events.</p>
        </div>
      </div>
    </section>
    <br>
    <section style="padding: 40px 24px; text-align: center;">
      <div style="max-width: 900px; margin: 0 auto;">
        <h3 style="margin: 0 0 8px;">View Our Gallery</h3>
        <p style="margin: 0 0 16px;">
          See the magic that happens at Countryside Paradise
        </p>
        <a href="/gallery" class="card" style="padding:12px 16px; display:inline-block;">Gallery</a>
      </div>
    </section>

  </main>
  <%- include("includes/footer") %>
</body>
</html>
